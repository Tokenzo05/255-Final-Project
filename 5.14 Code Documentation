#include <iostream>
#include <iomanip>
#include <fstream>
#include <string>

using namespace std;

// ============================================================================
// 1. MENU MODULE (Menu.h)
// ============================================================================
/**
 * Displays the application interface choices and handles input validation
 * for the user's menu selection.
 * * @return int - The validated user choice (0-4)
 */
int displayMenu()
{
    int choice;

    cout << "\n===== Temperature Converter =====" << endl;
    cout << "1. Fahrenheit to Celsius" << endl;
    cout << "2. Celsius to Fahrenheit" << endl;
    cout << "3. View Conversion History" << endl;
    cout << "4. Exit" << endl;
    cout << "Enter your choice: ";

    if (!(cin >> choice))
    {
        cout << "Invalid input. Please enter a number.\n";
        cin.clear();
        cin.ignore(1000, '\n');
        return 0; // Returns an out-of-range flag to trigger the default loop warning
    }

    return choice;
}

// ============================================================================
// 2. CALCULATE ONE MODULE (calculateOne.h)
// ============================================================================
/**
 * Converts a temperature from Fahrenheit to Celsius.
 * * @param fahrenheit - The input temperature in Fahrenheit
 * @return double - The converted temperature in Celsius
 */
double fahrenheitToCelsius(double fahrenheit)
{
    return (fahrenheit - 32) * 5.0 / 9.0;
}

// ============================================================================
// 3. CALCULATE TWO MODULE (calculateTwo.h)
// ============================================================================
/**
 * Converts a temperature from Celsius to Fahrenheit.
 * * @param celsius - The input temperature in Celsius
 * @return double - The converted temperature in Fahrenheit
 */
double celsiusToFahrenheit(double celsius)
{
    return (celsius * 9.0 / 5.0) + 32;
}

// ============================================================================
// 4. WRITE FILE MODULE (writeFile.h)
// ============================================================================
/**
 * Appends a formatted string log of a completed conversion to a text file.
 * * @param input - The baseline temperature entered by the user
 * @param output - The calculated temperature result
 * @param type - The direction string label (e.g., "F to C" or "C to F")
 */
void writeToFile(double input, double output, string type)
{
    ofstream outFile("temperature_log.txt", ios::app);

    if (outFile.is_open())
    {
        outFile << fixed << setprecision(2);
        outFile << type << ": " << input << " -> " << output << endl;
        outFile.close();
    }
    else
    {
        cout << "Error writing to file." << endl;
    }
}

// ============================================================================
// 5. READ FILE MODULE (readFile.h)
// ============================================================================
/**
 * Opens the log file and streams all historical conversions directly to the console.
 */
void readFromFile()
{
    ifstream inFile("temperature_log.txt");
    string line;

    if (inFile.is_open())
    {
        cout << "\n--- Conversion History ---\n";
        while (getline(inFile, line))
        {
            cout << line << endl;
        }
        inFile.close();
    }
    else
    {
        cout << "No history file found." << endl;
    }
}

// ============================================================================
// 6. MAIN LOOP MODULE (Mainloop.h)
// ============================================================================
/**
 * Acts as the centralized coordinator application block. Drives the menu state
 * machine and dispatches information to individual sub-functional blocks.
 */
void executeMainLoop()
{
    int choice;
    double temperature;

    cout << "Welcome to the Temperature Converter!" << endl;

    do
    {
        choice = displayMenu();

        switch (choice)
        {
        case 1:
        {
            cout << "\nEnter temperature in Fahrenheit: ";

            if (!(cin >> temperature))
            {
                cout << "Invalid input. Please enter a number.\n";
                cin.clear();
                cin.ignore(1000, '\n');
                break;
            }

            // Invokes Calculate One Module
            double result = fahrenheitToCelsius(temperature);

            cout << fixed << setprecision(2);
            cout << "\nTemperature in Celsius: " << result << " C" << endl;

            // Invokes Write File Module
            writeToFile(temperature, result, "F to C");
            break;
        }

        case 2:
        {
            cout << "\nEnter temperature in Celsius: ";

            if (!(cin >> temperature))
            {
                cout << "Invalid input. Please enter a number.\n";
                cin.clear();
                cin.ignore(1000, '\n');
                break;
            }

            // Invokes Calculate Two Module
            double result = celsiusToFahrenheit(temperature);

            cout << fixed << setprecision(2);
            cout << "\nTemperature in Fahrenheit: " << result << " F" << endl;

            // Invokes Write File Module
            writeToFile(temperature, result, "C to F");
            break;
        }

        case 3:
            // Invokes Read File Module
            readFromFile();
            break;

        case 4:
            cout << "\nProgram Ended." << endl;
            break;

        default:
            cout << "\nInvalid selection. Please try again." << endl;
        }

    } while (choice != 4);
}

// ============================================================================
// 7. MAIN ENTRY APPLICATION COMPONENT (main.cpp)
// ============================================================================
int main()
{
    // Simple handoff to the master loop handling state orchestration
    executeMainLoop();

    return 0;
}
